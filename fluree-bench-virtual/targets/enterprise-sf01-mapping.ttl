  rr:predicateObjectMap [ rr:predicate edw:openDate ;       rr:objectMap [ rr:column "OPEN_DATE" ; rr:datatype xsd:date ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:closeDate ;      rr:objectMap [ rr:column "CLOSE_DATE" ; rr:datatype xsd:date ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:status ;         rr:objectMap [ rr:column "STATUS" ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:priority ;       rr:objectMap [ rr:column "PRIORITY" ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:category ;       rr:objectMap [ rr:column "CATEGORY" ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:csatScore ;      rr:objectMap [ rr:column "CSAT_SCORE" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:resolutionHours ; rr:objectMap [ rr:column "RESOLUTION_HOURS" ; rr:datatype xsd:double ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:customer ;
    rr:objectMap [ rr:parentTriplesMap <#DimCustomer> ; rr:joinCondition [ rr:child "CUSTOMER_KEY" ; rr:parent "CUSTOMER_KEY" ] ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:product ;
    rr:objectMap [ rr:parentTriplesMap <#DimProduct> ; rr:joinCondition [ rr:child "PRODUCT_KEY" ; rr:parent "PRODUCT_KEY" ] ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:agent ;
    rr:objectMap [ rr:parentTriplesMap <#DimEmployee> ; rr:joinCondition [ rr:child "AGENT_KEY" ; rr:parent "EMPLOYEE_KEY" ] ] ] ;
  rr:predicateObjectMap [ rr:predicate edw:dateDim ;
    rr:objectMap [ rr:parentTriplesMap <#DimDate> ; rr:joinCondition [ rr:child "OPEN_DATE_KEY" ; rr:parent "DATE_KEY" ] ] ] .
