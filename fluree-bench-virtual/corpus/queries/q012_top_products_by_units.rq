# q012 top_products_by_units
# Intent: Fact->dim rollup with top-k and an SCD isCurrent filter.
# BI lineage (BI-08): "What are the top 10 products by units sold?"
# Predicates verified against enterprise.ttl — FactOrderLine: quantity, product; DimProduct: name, isCurrent.
PREFIX edw: <http://ns.fluree.dev/edw#>
SELECT ?pn (SUM(?qty) AS ?u)
WHERE { ?ol a edw:OrderLine ; edw:quantity ?qty ; edw:product ?p .
        ?p edw:name ?pn ; edw:isCurrent true . }
GROUP BY ?pn
ORDER BY DESC(?u)
LIMIT 10
