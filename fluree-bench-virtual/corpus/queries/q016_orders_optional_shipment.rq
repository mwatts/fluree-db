# q016 orders_optional_shipment
# Intent: OPTIONAL (left-join) fact-to-fact.
# BI lineage (BI-10): "List orders with their shipment status where one exists."
# Predicates verified against enterprise.ttl — FactOrder: orderId; FactShipment: order, shipStatus.
PREFIX edw: <http://ns.fluree.dev/edw#>
SELECT ?oid ?st
WHERE { ?o a edw:Order ; edw:orderId ?oid .
        OPTIONAL { ?sh edw:order ?o ; edw:shipStatus ?st . } }
LIMIT 5000
