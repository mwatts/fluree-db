# q013 products_above_avg_units
# Intent: Subquery (AVG of per-product sums); H8 non-lowered on virtual.
# BI lineage (BI-08): "Which products sell above the average units-per-product?"
# Predicates verified against enterprise.ttl — FactOrderLine: quantity, product; DimProduct: name, isCurrent.
PREFIX edw: <http://ns.fluree.dev/edw#>
SELECT ?pn ?u
WHERE {
  { SELECT ?pn (SUM(?qty) AS ?u)
    WHERE { ?ol a edw:OrderLine ; edw:quantity ?qty ; edw:product ?p .
            ?p edw:name ?pn ; edw:isCurrent true . }
    GROUP BY ?pn }
  { SELECT (AVG(?u2) AS ?avg)
    WHERE { SELECT ?p2 (SUM(?q2) AS ?u2)
            WHERE { ?ol2 a edw:OrderLine ; edw:quantity ?q2 ; edw:product ?p2 . }
            GROUP BY ?p2 } }
  FILTER(?u > ?avg)
}
