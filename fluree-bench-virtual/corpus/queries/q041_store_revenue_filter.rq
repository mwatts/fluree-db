# q041 store_revenue_filter
# Intent: filter_iri A/B twin of q040 (FILTER form; same full scan on virtual).
# BI lineage (BI-19): "Same three-store revenue, expressed as an IRI-equality FILTER."
# Predicates verified against enterprise.ttl — FactOrder: store, orderTotal.
PREFIX edw: <http://ns.fluree.dev/edw#>
SELECT ?store ?tot
WHERE { ?o a edw:Order ; edw:store ?store ; edw:orderTotal ?tot .
         FILTER(?store = <http://data.fluree.dev/edw/store/1> || ?store = <http://data.fluree.dev/edw/store/2> || ?store = <http://data.fluree.dev/edw/store/3>) }
