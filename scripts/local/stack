# ============================================================================
# Subcommand: partition (raft only)
# ============================================================================

cmd_partition() {
    case "${1:-}" in
        -h|--help) usage_partition; return 0 ;;
        "") die "usage: $(basename "$0") partition <target>" ;;
    esac
    [ $# -eq 1 ] || die "usage: $(basename "$0") partition <target>"

    require_raft_mode partition

    local target="$1"
    local host
    host="$(resolve_target_host "$target")"
    local network="${COMPOSE_PROJECT}_$NETWORK_NAME"

    # Idempotency: if the container isn't on the network, treat as
    # already-partitioned. `docker network disconnect` errors hard
    # otherwise.
    if ! docker network inspect "$network" \
            --format '{{range .Containers}}{{.Name}} {{end}}' 2>/dev/null \
            | grep -qw "$host"; then
        warn "$host is already disconnected from $network"
        return 0
    fi

    info "Disconnecting $host from $network..."
    docker network disconnect "$network" "$host" >/dev/null
    ok "$host partitioned. Heal with: $(basename "$0") heal $target"
}

# ============================================================================
# Subcommand: heal (raft only)
# ============================================================================

cmd_heal() {
    case "${1:-}" in
        -h|--help) usage_heal; return 0 ;;
        "") die "usage: $(basename "$0") heal <target>" ;;
    esac
    [ $# -eq 1 ] || die "usage: $(basename "$0") heal <target>"

    require_raft_mode heal

    local host
    host="$(resolve_target_host "$1")"
    local network="${COMPOSE_PROJECT}_$NETWORK_NAME"

    if docker network inspect "$network" \
            --format '{{range .Containers}}{{.Name}} {{end}}' 2>/dev/null \
            | grep -qw "$host"; then
        warn "$host is already connected to $network"
        return 0
    fi

    # Re-attach with the same network alias so peers / raft peers'
    # hostname-based URLs resolve to the new IP.
    info "Reconnecting $host to $network..."
    docker network connect --alias "$host" "$network" "$host" >/dev/null
    ok "$host healed. Inspect with: $(basename "$0") status"
}

# ============================================================================
# Subcommand: repoint (peer failover)
# ============================================================================

cmd_repoint() {
    case "${1:-}" in
        -h|--help) usage_repoint; return 0 ;;
        "") die "usage: $(basename "$0") repoint <peer-N> <fluree-M>" ;;
    esac
    [ $# -eq 2 ] || die "usage: $(basename "$0") repoint <peer-N> <fluree-M>"

    detect_compose

    local peer_arg="$1"
    local target_arg="$2"

    # Parse the peer id: `peer-N` or bare `N`. Rejecting bare fluree
    # ids explicitly makes the intent unambiguous.
    local peer_id=""
    if [[ "$peer_arg" =~ ^peer-([1-9][0-9]*)$ ]]; then
        peer_id="${BASH_REMATCH[1]}"
    elif [[ "$peer_arg" =~ ^[1-9][0-9]*$ ]]; then
        peer_id="$peer_arg"
    else
        die "invalid peer: $peer_arg (expected \`peer-N\` or a bare peer number)"
    fi
    require_peer_in_range "$peer_id"

    # Parse the target: `fluree-M` or bare `M`.
    local target_id=""
    if [[ "$target_arg" =~ ^fluree-([1-9][0-9]*)$ ]]; then
        target_id="${BASH_REMATCH[1]}"
    elif [[ "$target_arg" =~ ^[1-9][0-9]*$ ]]; then
        target_id="$target_arg"
    else
        die "invalid target: $target_arg (expected \`fluree-M\` or a bare raft node number)"
    fi
    require_node_in_range "$target_id"

    local peer
    peer="$(peer_host "$peer_id")"
    local target_host
    target_host="$(node_host "$target_id")"
    local internal_public
    internal_public="$(node_internal_public 1)"
    local new_tx_url="http://$target_host:$internal_public"
    local new_events_url="http://$target_host:$internal_public/v1/fluree/events"

    info "Rewriting compose entries for $peer to subscribe to $target_host..."
    # 1. Update the header-comment record so `status` and later
    #    `repoint` invocations reflect the new mapping.
    # 2. Update the two env vars on the peer service.
    # In-place edits with a portable sed (works on GNU + BSD via -i''):
    sed -i.bak \
        -e "s|^# Peer-$peer_id-target: .*|# Peer-$peer_id-target: $target_host|" \
        "$COMPOSE_FILE"

    # For the env-var rewrites we need to touch only the lines under
    # the `$peer:` service block. awk is the safest way — sed can't
    # cleanly scope a substitution to a YAML sub-block.
    awk -v peer="$peer" \
        -v new_tx="$new_tx_url" \
        -v new_events="$new_events_url" \
        '
        BEGIN { in_peer = 0 }
        # New service block begins at column 2 with `<name>:`.
        /^  [A-Za-z][A-Za-z0-9-]*:/ {
            in_peer = ($1 == peer ":") ? 1 : 0
        }
        in_peer && /FLUREE_TX_SERVER_URL:/ {
            sub(/"http:[^"]*"/, "\"" new_tx "\"")
        }
        in_peer && /FLUREE_PEER_EVENTS_URL:/ {
            sub(/"http:[^"]*"/, "\"" new_events "\"")
        }
        { print }
        ' "$COMPOSE_FILE" > "$COMPOSE_FILE.new"
    mv "$COMPOSE_FILE.new" "$COMPOSE_FILE"
    rm -f "$COMPOSE_FILE.bak"

    info "Recreating $peer with the new configuration..."
    "${DOCKER_COMPOSE[@]}" -p "$COMPOSE_PROJECT" -f "$COMPOSE_FILE" \
        up -d --force-recreate --no-deps "$peer" >/dev/null

    info "Waiting for $peer to come healthy..."
    local public_url deadline
    public_url="$(peer_host_public_url "$peer_id")"
    deadline=$(( $(date +%s) + 30 ))
    while ! curl -fsS -m 2 "$public_url/health" >/dev/null 2>&1; do
        if [ "$(date +%s)" -gt "$deadline" ]; then
            err "$peer restarted but /health didn't respond within 30s"
            docker logs --tail 30 "$peer"
            exit 1
        fi
        sleep 0.5
    done
    ok "$peer now subscribed to $target_host"
}

# ============================================================================
# Subcommand: logs
# ============================================================================

cmd_logs() {
    local follow=0
    local tail_lines=""
    local target=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help) usage_logs; return 0 ;;
            -f|--follow) follow=1; shift ;;
            --tail)
                [ $# -ge 2 ] || die "--tail requires an argument"
                tail_lines="$2"; shift 2 ;;
            [1-9]|[1-9][0-9]|peer-[1-9]|peer-[1-9][0-9])
                target="$1"; shift ;;
            *) die "Unknown argument: $1 (try: $(basename "$0") help logs)" ;;
        esac
    done

    local args=()
    [ "$follow" -eq 1 ] && args+=(-f)
    [ -n "$tail_lines" ] && args+=(--tail "$tail_lines")

    if [ -n "$target" ]; then
        local host
        host="$(resolve_target_host "$target")"
        docker logs "${args[@]}" "$host"
    else
        detect_compose
        [ -f "$COMPOSE_FILE" ] || die "No deployment running. Start one with: $(basename "$0") up"
        "${DOCKER_COMPOSE[@]}" -p "$COMPOSE_PROJECT" -f "$COMPOSE_FILE" logs "${args[@]}"
    fi
}

# ============================================================================
# Subcommand: load
# ============================================================================

cmd_load() {
    case "${1:-}" in
        -h|--help)
            usage_load
            return 0
            ;;
        --tool-help)
            shift
            ensure_load_built
            exec "$BUILD_DIR/fluree-load" --help
            ;;
    esac

    # Computing addrs against the live compose file is the convenience
    # — if the caller wants to point at something else they can pass
    # their own --addrs and we leave it alone.
    local has_addrs=0
    for arg in "$@"; do
        case "$arg" in
            --addrs|--addrs=*) has_addrs=1 ;;
        esac
    done

    local args=("$@")
    if [ "$has_addrs" -eq 0 ]; then
        local node_count
        node_count="$(read_node_count)"
        local addrs=""
        local i
        for i in $(seq 1 "$node_count"); do
            local url
            url="$(node_host_public_url "$i")"
            if [ -z "$addrs" ]; then
                addrs="$url"
            else
                addrs="$addrs,$url"
            fi
        done
        args=("--addrs" "$addrs" "${args[@]}")
    fi

    ensure_load_built
    exec "$BUILD_DIR/fluree-load" "${args[@]}"
}

ensure_load_built() {
    local load_dir="$LOCAL_DIR/load"
    [ -d "$load_dir" ] || die "load tool source missing at $load_dir"
    local bin="$BUILD_DIR/fluree-load"
    # Skip the build if the cached binary is newer than every source
    # file. Fast no-op when the user just wants to re-run the same
    # workload against a live deployment.
    if [ -x "$bin" ]; then
        local newest_src
        newest_src=$(find "$load_dir/src" "$load_dir/Cargo.toml" -newer "$bin" 2>/dev/null | head -1)
        if [ -z "$newest_src" ]; then
            return 0
        fi
    fi
    info "Building fluree-load (release)..."
    ( cd "$load_dir" && cargo build --release )
    mkdir -p "$BUILD_DIR"
    cp "$load_dir/target/release/fluree-load" "$bin"
    ok "fluree-load built and cached at .build/fluree-load"
}

# ============================================================================
# Dispatch
# ============================================================================

if [ $# -eq 0 ]; then
    usage_top
    exit 1
fi

cmd="$1"
shift

case "$cmd" in
    up)             cmd_up "$@" ;;
    down)           cmd_down "$@" ;;
    status)         cmd_status "$@" ;;
    kill)           cmd_kill "$@" ;;
    restart)        cmd_restart "$@" ;;
    pause)          cmd_pause "$@" ;;
    unpause)        cmd_unpause "$@" ;;
    partition)      cmd_partition "$@" ;;
    heal)           cmd_heal "$@" ;;
    repoint)        cmd_repoint "$@" ;;
    logs)           cmd_logs "$@" ;;
    load)           cmd_load "$@" ;;
    help|-h|--help) cmd_help "$@" ;;
    *)              err "Unknown command: $cmd"; usage_top; exit 1 ;;
esac
